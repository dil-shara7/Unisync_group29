<?xml version="1.0" encoding="utf-8"?>
<!--
  Text appearances + button styles derived from Login (node 8:274).
-->
<resources>

    <!-- Text appearances -->
    <style name="TextAppearance.UniSync.Logo" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">@font/joti_one</item>
        <item name="android:textSize">@dimen/text_size_display</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.UniSync.Tagline" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/josefin_slab_semibold_italic</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">italic</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.UniSync.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/jomolhari</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.UniSync.InputPlaceholder" parent="TextAppearance.UniSync.Body">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.UniSync.Caption" parent="TextAppearance.UniSync.Body">
        <item name="android:textSize">@dimen/text_size_body_small</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Input field (flat rounded rect, no floating label — matches Figma) -->
    <style name="Widget.UniSync.InputField" parent="">
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:textAppearance">@style/TextAppearance.UniSync.Body</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:paddingStart">@dimen/input_text_padding_start</item>
        <item name="android:paddingEnd">@dimen/input_text_padding_start</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:minHeight">@dimen/input_field_height</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Primary button (mauve) -->
    <style name="Widget.UniSync.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextAppearance.UniSync.Body</item>
        <item name="backgroundTint">@color/primary_purple</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">@dimen/radius_input</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">@dimen/elevation_none</item>
    </style>

    <!-- Social button: light variant (Google) -->
    <style name="Widget.UniSync.Button.Social.Light" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextAppearance.UniSync.Body</item>
        <item name="backgroundTint">@color/primary_purple_light</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">@dimen/radius_input</item>
        <item name="android:minHeight">@dimen/button_height_social</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">@dimen/elevation_none</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/spacing_sm</item>
        <item name="iconSize">@dimen/icon_size_social</item>
        <item name="iconTint">@android:color/transparent</item>
    </style>

    <!-- Social button: primary variant (Facebook) -->
    <style name="Widget.UniSync.Button.Social.Primary" parent="Widget.UniSync.Button.Social.Light">
        <item name="backgroundTint">@color/primary_purple</item>
    </style>

    <!-- Text link (Sign Up, Forgot password) -->
    <style name="Widget.UniSync.TextLink" parent="">
        <item name="android:textAppearance">@style/TextAppearance.UniSync.Body</item>
        <item name="android:textColor">@color/text_link</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:padding">@dimen/spacing_xs</item>
    </style>

</resources>
