<?xml version="1.0" encoding="utf-8"?>
<!--
  Checkout — Figma "Marketplace-screen 11".
  Bottom nav pinned to bottom; form scrolls in middle.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fitsSystemWindows="true"
    tools:context=".MarketplaceCheckoutActivity">

    <include
        android:id="@+id/status_bar"
        layout="@layout/include_status_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/back_button"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_back"
        android:padding="2dp"
        android:rotation="180"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/status_bar" />

    <TextView
        android:id="@+id/header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:text="checkout"
        android:textAppearance="@style/TextAppearance.UniSync.Logo"
        android:textSize="@dimen/text_size_title_large"
        app:layout_constraintBottom_toBottomOf="@id/back_button"
        app:layout_constraintStart_toEndOf="@id/back_button"
        app:layout_constraintTop_toTopOf="@id/back_button" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_button">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/spacing_xl">

            <TextView
                android:id="@+id/label_delivery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                android:text="Delivery Info:"
                android:textAppearance="@style/TextAppearance.UniSync.Body"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/edit_delivery"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/edit_delivery"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="@dimen/spacing_md"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Edit delivery info"
                android:src="@android:drawable/ic_menu_edit"
                app:layout_constraintBottom_toBottomOf="@id/label_delivery"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/label_delivery" />

            <EditText
                android:id="@+id/delivery_address"
                style="@style/Widget.UniSync.InputField"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_md"
                android:autofillHints="postalAddress"
                android:hint="Delivery address"
                android:inputType="textPostalAddress"
                android:text="No:05, Colombo 14, Sri Lanka"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/label_delivery" />

            <TextView
                android:id="@+id/label_payment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="Payment Info:"
                android:textAppearance="@style/TextAppearance.UniSync.Body"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/delivery_address" />

            <RadioGroup
                android:id="@+id/payment_group"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_md"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/label_payment">

                <LinearLayout
                    android:id="@+id/payment_card"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_field"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">
                    <ImageView android:layout_width="40dp" android:layout_height="24dp" android:contentDescription="@null" android:src="@android:drawable/ic_menu_view" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/spacing_md" android:layout_weight="1" android:text="Credit Card\n4455 **** ****" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <RadioButton android:id="@+id/payment_card_radio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:clickable="false" android:focusable="false" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/payment_paypal"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_input_field"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">
                    <ImageView android:layout_width="40dp" android:layout_height="24dp" android:contentDescription="@null" android:src="@android:drawable/ic_menu_send" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/spacing_md" android:layout_weight="1" android:text="PayPal" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <RadioButton android:id="@+id/payment_paypal_radio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:clickable="false" android:focusable="false" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/payment_cod"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_input_field"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">
                    <ImageView android:layout_width="40dp" android:layout_height="24dp" android:contentDescription="@null" android:src="@android:drawable/ic_menu_save" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/spacing_md" android:layout_weight="1" android:text="Cash On Delivery" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <RadioButton android:id="@+id/payment_cod_radio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:clickable="false" android:focusable="false" />
                </LinearLayout>
            </RadioGroup>

            <TextView
                android:id="@+id/label_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="Order Summery:"
                android:textAppearance="@style/TextAppearance.UniSync.Body"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/payment_group" />

            <LinearLayout
                android:id="@+id/summary_rows"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_md"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/label_summary">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sub Total" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <TextView android:id="@+id/sub_total" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="@style/TextAppearance.UniSync.Body" tools:text="$55" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Shipping fee" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$10" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Service charge" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$5" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="6dp" android:paddingBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total" android:textAppearance="@style/TextAppearance.UniSync.Body" android:textSize="@dimen/text_size_title" android:textStyle="bold" />
                    <TextView android:id="@+id/total_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="@style/TextAppearance.UniSync.Body" android:textSize="@dimen/text_size_title" android:textStyle="bold" tools:text="$65" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/confirm_button"
                style="@style/Widget.UniSync.Button.Primary"
                android:layout_width="200dp"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="Confirm Payment"
                app:cornerRadius="@dimen/radius_input"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/summary_rows" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/include_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
