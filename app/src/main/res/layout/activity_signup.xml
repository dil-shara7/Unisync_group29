<?xml version="1.0" encoding="utf-8"?>
<!--
  Sign Up form. Same visual language as Login, but with Name field added.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".SignUpActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            android:id="@+id/logo_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.UniSync.Logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tagline_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your campus account"
            android:textAppearance="@style/TextAppearance.UniSync.Tagline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logo_text" />

        <EditText
            android:id="@+id/name_input"
            style="@style/Widget.UniSync.InputField"
            android:layout_width="0dp"
            android:layout_height="@dimen/input_field_height"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:autofillHints="name"
            android:hint="Full name"
            android:inputType="textPersonName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tagline_text" />

        <EditText
            android:id="@+id/email_input"
            style="@style/Widget.UniSync.InputField"
            android:layout_width="0dp"
            android:layout_height="@dimen/input_field_height"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:autofillHints="emailAddress"
            android:hint="@string/auth_email"
            android:inputType="textEmailAddress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/name_input" />

        <EditText
            android:id="@+id/password_input"
            style="@style/Widget.UniSync.InputField"
            android:layout_width="0dp"
            android:layout_height="@dimen/input_field_height"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:autofillHints="password"
            android:hint="@string/auth_password"
            android:inputType="textPassword"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/email_input" />

        <EditText
            android:id="@+id/student_id_input"
            style="@style/Widget.UniSync.InputField"
            android:layout_width="0dp"
            android:layout_height="@dimen/input_field_height"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:autofillHints="username"
            android:hint="Student ID (optional)"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/password_input" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/signup_button"
            style="@style/Widget.UniSync.Button.Primary"
            android:layout_width="184dp"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/auth_sign_up"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/student_id_input" />

        <TextView
            android:id="@+id/login_prompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="@dimen/spacing_xs"
            android:text="Already have an account? Log In"
            android:textAppearance="@style/TextAppearance.UniSync.Body"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/signup_button" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
