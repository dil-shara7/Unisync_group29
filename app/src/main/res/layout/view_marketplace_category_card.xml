<?xml version="1.0" encoding="utf-8"?>
<!--
  Marketplace category card. 357x128dp (#af8fad bg) with 99x99 image on left,
  category title + "View Details" pill on right.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/mp_card_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_accent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/mp_card_image"
        android:layout_width="@dimen/marketplace_card_image_size"
        android:layout_height="@dimen/marketplace_card_image_size"
        android:layout_marginStart="11dp"
        android:contentDescription="@string/cd_product_image"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/mp_card_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.UniSync.Body"
        tools:text="Category"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/mp_card_image"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mp_card_view_details"
        style="@style/Widget.UniSync.Button.Social.Light"
        android:layout_width="105dp"
        android:layout_height="@dimen/button_height_pill"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="@string/action_view_details"
        android:textSize="@dimen/text_size_caption"
        app:cornerRadius="@dimen/radius_pill_button"
        app:layout_constraintStart_toStartOf="@id/mp_card_title"
        app:layout_constraintTop_toBottomOf="@id/mp_card_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
