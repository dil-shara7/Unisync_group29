<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable Home feature card: dark mauve top half (icon) + light bottom label strip.
  Used 4× on Home. Each <include> uses android:id so ViewBinding scopes inner
  view ids under that include's sub-binding.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/feature_card_top"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/feature_card_bottom_strip" />

    <ImageView
        android:id="@+id/feature_card_icon"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:contentDescription="@string/cd_category_icon"
        android:src="@android:drawable/ic_menu_view"
        app:layout_constraintBottom_toTopOf="@id/feature_card_bottom_strip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/feature_card_bottom_strip"
        android:layout_width="0dp"
        android:layout_height="@dimen/card_bottom_strip_height"
        android:background="@drawable/bg_card_bottom_strip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/feature_card_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:textAppearance="@style/TextAppearance.UniSync.Body"
        tools:text="Title"
        app:layout_constraintEnd_toEndOf="@id/feature_card_bottom_strip"
        app:layout_constraintStart_toStartOf="@id/feature_card_bottom_strip"
        app:layout_constraintTop_toTopOf="@id/feature_card_bottom_strip" />

    <TextView
        android:id="@+id/feature_card_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/TextAppearance.UniSync.Caption"
        android:textColor="@color/text_primary"
        tools:text="Subtitle"
        app:layout_constraintEnd_toEndOf="@id/feature_card_bottom_strip"
        app:layout_constraintStart_toStartOf="@id/feature_card_bottom_strip"
        app:layout_constraintTop_toBottomOf="@id/feature_card_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
