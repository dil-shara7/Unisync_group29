<?xml version="1.0" encoding="utf-8"?>
<!--
  User Profile — Figma "User Profile" (162:121).
  Bottom nav pinned to parent bottom; only profile card scrolls.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profile_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fitsSystemWindows="true"
    tools:context=".ProfileActivity">

    <include
        android:id="@+id/status_bar"
        layout="@layout/include_status_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/profile_back"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_back"
        android:padding="2dp"
        android:rotation="180"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/status_bar" />

    <TextView
        android:id="@+id/profile_header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:text="@string/profile_title"
        android:textAppearance="@style/TextAppearance.UniSync.Logo"
        android:textSize="@dimen/text_size_title_large"
        app:layout_constraintBottom_toBottomOf="@id/profile_back"
        app:layout_constraintStart_toEndOf="@id/profile_back"
        app:layout_constraintTop_toTopOf="@id/profile_back" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profile_back">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/profile_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_md"
            android:background="@drawable/bg_profile_card"
            android:padding="@dimen/spacing_md">

            <ImageView
                android:id="@+id/profile_avatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_avatar_blue"
                android:contentDescription="@string/cd_user_avatar"
                android:padding="@dimen/spacing_xs"
                android:src="@drawable/ic_avatar_student"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/profile_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:textAppearance="@style/TextAppearance.UniSync.Body"
                android:textSize="@dimen/text_size_label"
                android:textStyle="bold"
                tools:text="Alex Raw"
                app:layout_constraintEnd_toStartOf="@id/profile_edit_button"
                app:layout_constraintStart_toEndOf="@id/profile_avatar"
                app:layout_constraintTop_toTopOf="@id/profile_avatar" />

            <TextView
                android:id="@+id/profile_email"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.UniSync.Caption"
                android:textColor="@color/text_primary"
                tools:text="alex09@uni.edu.lk"
                app:layout_constraintEnd_toStartOf="@id/profile_edit_button"
                app:layout_constraintStart_toStartOf="@id/profile_name"
                app:layout_constraintTop_toBottomOf="@id/profile_name" />

            <TextView
                android:id="@+id/profile_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.UniSync.Caption"
                android:textColor="@color/text_primary"
                tools:text="ICT/2026/013"
                app:layout_constraintEnd_toStartOf="@id/profile_edit_button"
                app:layout_constraintStart_toStartOf="@id/profile_name"
                app:layout_constraintTop_toBottomOf="@id/profile_email" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/profile_edit_button"
                style="@style/Widget.UniSync.Button.Primary"
                android:layout_width="64dp"
                android:layout_height="32dp"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:text="Edit"
                android:textSize="@dimen/text_size_caption"
                app:cornerRadius="@dimen/radius_pill_button"
                app:layout_constraintBottom_toBottomOf="@id/profile_avatar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/profile_avatar" />

            <TextView
                android:id="@+id/section_academic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_section_header"
                android:padding="@dimen/spacing_sm"
                android:text="Academic Info"
                android:textAppearance="@style/TextAppearance.UniSync.Body"
                android:textColor="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/profile_avatar" />

            <LinearLayout
                android:id="@+id/academic_rows"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_sm"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/section_academic">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Student ID:" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <TextView android:id="@+id/row_student_id" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textAppearance="@style/TextAppearance.UniSync.Body" tools:text="Alex Raw" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Faculty:" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <TextView android:id="@+id/row_faculty" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textAppearance="@style/TextAppearance.UniSync.Body" tools:text="Computing &amp; Technology" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Program:" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <TextView android:id="@+id/row_program" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textAppearance="@style/TextAppearance.UniSync.Body" tools:text="Bsc (Hons) in Network Science" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Year:" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                    <TextView android:id="@+id/row_year" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textAppearance="@style/TextAppearance.UniSync.Body" tools:text="Year - 3" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_dashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_sm"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/academic_rows">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dashboard" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:contentDescription="@null" android:src="@android:drawable/ic_media_play" />
            </LinearLayout>

            <TextView
                android:id="@+id/section_account"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_header"
                android:padding="@dimen/spacing_sm"
                android:text="Account"
                android:textAppearance="@style/TextAppearance.UniSync.Body"
                android:textColor="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/row_dashboard" />

            <LinearLayout
                android:id="@+id/account_rows"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/section_account">

                <LinearLayout android:id="@+id/row_settings" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingTop="8dp" android:paddingBottom="8dp">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:contentDescription="@null" android:src="@android:drawable/ic_menu_preferences" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/spacing_md" android:layout_weight="1" android:text="@string/profile_settings" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                </LinearLayout>

                <LinearLayout android:id="@+id/row_notifications" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingTop="8dp" android:paddingBottom="8dp">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:contentDescription="@null" android:src="@android:drawable/ic_popup_reminder" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/spacing_md" android:layout_weight="1" android:text="Notifications" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                </LinearLayout>

                <LinearLayout android:id="@+id/row_logout" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingTop="8dp" android:paddingBottom="8dp">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:contentDescription="@null" android:src="@android:drawable/ic_lock_power_off" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="@dimen/spacing_md" android:layout_weight="1" android:text="@string/profile_logout" android:textAppearance="@style/TextAppearance.UniSync.Body" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profile_action_tiles"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/account_rows">

                <LinearLayout android:id="@+id/tile_cart" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="@dimen/spacing_sm" android:layout_weight="1" android:background="@drawable/bg_action_tile" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:gravity="center" android:orientation="vertical" android:padding="@dimen/spacing_sm">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="@null" android:src="@android:drawable/ic_menu_add" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Cart Items" android:textAppearance="@style/TextAppearance.UniSync.Caption" android:textColor="@color/text_primary" />
                </LinearLayout>

                <LinearLayout android:id="@+id/tile_sold" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="@dimen/spacing_sm" android:layout_weight="1" android:background="@drawable/bg_action_tile" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:gravity="center" android:orientation="vertical" android:padding="@dimen/spacing_sm">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="@null" android:src="@android:drawable/ic_menu_sort_by_size" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Sold Items" android:textAppearance="@style/TextAppearance.UniSync.Caption" android:textColor="@color/text_primary" />
                </LinearLayout>

                <LinearLayout android:id="@+id/tile_wallet" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_action_tile" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:gravity="center" android:orientation="vertical" android:padding="@dimen/spacing_sm">
                    <ImageView android:layout_width="28dp" android:layout_height="28dp" android:contentDescription="@null" android:src="@android:drawable/ic_menu_save" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="My Wallet" android:textAppearance="@style/TextAppearance.UniSync.Caption" android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/include_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
